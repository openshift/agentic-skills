{
  "always_include_kubelet_files": false,
  "must_gather_docs_dir": "DataSource",
  "must_gather_base_dir": "",
  "must_gather_incoming_dir": "/tmp/must-gather-incoming",
  "must_gather_wait_seconds": 120,
  "claude": {
    "max_chunk_tokens": 80000
  },
  "agent": {
    "max_iterations": 25,
    "max_deepening_rounds": 3
  },
  "notes": {
    "always_include_kubelet_files": "Set to true to always add kubelet_service.* and kubelet_journal.* to analysis/RCA; false to use only LLM-suggested files",
    "must_gather_docs_dir": "Path to must-gather documentation directory (MUST_GATHER_*.md files). Relative paths are resolved from the project root. Default: DataSource",
    "must_gather_base_dir": "Path to the must-gather root folder (namespaces/, cluster-scoped-resources/, etc.). Can be absolute or relative to project root. Overridden by the API request value when provided.",
    "must_gather_incoming_dir": "Directory where oc cp deposits the must-gather data. Copy with: oc cp <must-gather-dir> <sandbox-pod>:<this-path>. Default: /tmp/must-gather-incoming",
    "must_gather_wait_seconds": "Fixed sleep in seconds before reading must-gather data. Must be long enough for oc cp to complete. Default: 120",
    "max_chunk_tokens": "RCA chunking budget for large must-gathers (default 80000). Increase if the orchestrating LLM supports a larger context window.",
    "max_iterations": "Maximum tool-call iterations for the ReAct agent loop (default: 25)",
    "max_deepening_rounds": "Maximum deepening rounds HIGH -> MEDIUM -> LOW (default: 3)"
  }
}
